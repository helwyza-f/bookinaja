{
  "expo": {
    "name": "Bookinaja Mobile",
    "slug": "bookinaja-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": [
      "bookinaja"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookinaja.mobile",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "Bookinaja membutuhkan akses jaringan lokal saat development untuk terhubung ke backend di komputer ini."
      }
    },
    "android": {
      "package": "com.bookinaja.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08111f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.39127355505-69ph15i21481t87eoktnj2462h6ofp5h"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
