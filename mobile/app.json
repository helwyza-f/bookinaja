{
  "expo": {
    "name": "Bookinaja",
    "slug": "bookinaja-mobile",
    "scheme": [
      "bookinaja",
      "com.googleusercontent.apps.39127355505-69ph15i21481t87eoktnj2462h6ofp5h",
      "com.googleusercontent.apps.39127355505-pp4rj37f5qa4mag36dj597j03o2mkvjm"
    ],
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bookinaja.mobile",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "Bookinaja membutuhkan akses jaringan lokal saat development untuk terhubung ke backend di komputer ini."
      }
    },
    "android": {
      "package": "com.bookinaja.mobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    }
  }
}
